{
  "name": "huddle-desktop",
  "version": "1.0.0",
  "description": "Huddle - Simple, secure video calls",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.huddle.meet",
    "productName": "Huddle",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "server.py",
      "media_worker.js",
      "static/**/*",
      "requirements.txt",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "desktop/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "desktop/icon.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "desktop/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "desktop/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  },
  "author": "Huddle",
  "license": "MIT"
}
